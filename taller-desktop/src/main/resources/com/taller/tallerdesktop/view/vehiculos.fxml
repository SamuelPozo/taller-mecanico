<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.taller.tallerdesktop.controller.VehiculosController"
      spacing="16" style="-fx-background-color: transparent;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Gestión de Vehículos"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #EAEAEA;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField"
                   promptText="🔍  Buscar por matrícula, marca o modelo..."
                   prefWidth="300"
                   styleClass="login-field"/>
        <Button text="+ Nuevo Vehículo"
                styleClass="btn-primary"
                prefWidth="160"
                onAction="#handleNuevoVehiculo"/>
    </HBox>

    <!-- TABLA -->
    <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
        <TableView fx:id="vehiculosTable" styleClass="table-view" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colMatricula" text="Matrícula" prefWidth="110"/>
                <TableColumn fx:id="colMarca" text="Marca" prefWidth="120"/>
                <TableColumn fx:id="colModelo" text="Modelo" prefWidth="140"/>
                <TableColumn fx:id="colAnio" text="Año" prefWidth="70"/>
                <TableColumn fx:id="colColor" text="Color" prefWidth="90"/>
                <TableColumn fx:id="colCliente" text="Cliente" prefWidth="200"/>
                <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="150"/>
            </columns>
            <placeholder>
                <Label text="No hay vehículos registrados."
                       style="-fx-text-fill: #A0A0B0;"/>
            </placeholder>
        </TableView>
    </VBox>

</VBox>