<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.taller.tallerdesktop.controller.AusenciasController"
      spacing="16" style="-fx-background-color: transparent;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Gestión de Ausencias"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #EAEAEA;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="filtroEstado" promptText="Filtrar por estado" prefWidth="180"/>
    </HBox>

    <!-- TABLA -->
    <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">
        <TableView fx:id="ausenciasTable" styleClass="table-view" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="55"/>
                <TableColumn fx:id="colMecanico" text="Mecánico" prefWidth="180"/>
                <TableColumn fx:id="colTipo" text="Tipo" prefWidth="120"/>
                <TableColumn fx:id="colInicio" text="Fecha Inicio" prefWidth="120"/>
                <TableColumn fx:id="colFin" text="Fecha Fin" prefWidth="120"/>
                <TableColumn fx:id="colMotivo" text="Motivo" prefWidth="200"/>
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="120"/>
                <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="150"/>
            </columns>
            <placeholder>
                <Label text="No hay ausencias registradas."
                       style="-fx-text-fill: #A0A0B0;"/>
            </placeholder>
        </TableView>
    </VBox>

</VBox>